// Discord Watchtower — Prisma Schema
// Privileged Identity Manager for Discord

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Per-guild configuration
model GuildConfig {
  id                 String   @id @default(cuid())
  guildId            String   @unique
  // How long (in seconds) an elevated role session lasts
  sessionDurationSec Int      @default(3600)
  // How many failed password attempts before lockout
  lockoutThreshold   Int      @default(5)
  // Discord channel ID where elevation alerts are posted
  alertChannelId     String?
  // Discord channel ID where audit logs are posted
  auditChannelId     String?
  // Discord role ID for the Watchtower Admin role; null = not configured (bootstrap: Administrator fallback)
  adminRoleId        String?
  // Seconds before expiry to post a warning message; 0 = disabled
  notifyBeforeSec    Int      @default(300)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@map("guild_configs")
}

// Users who have registered a PIM password
model PimUser {
  id             String   @id @default(cuid())
  discordUserId  String
  guildId        String
  passwordHash   String?
  failedAttempts Int      @default(0)
  lockedAt       DateTime?
  // Set by admin "Remove Permission and Block" action; prevents future elevations until cleared
  blockedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  eligibleRoles   EligibleRole[]
  activeElevations ActiveElevation[]
  auditLogs        AuditLog[]

  @@unique([discordUserId, guildId])
  @@map("pim_users")
}

// Roles a user is eligible to elevate into
model EligibleRole {
  id            String   @id @default(cuid())
  pimUserId     String
  roleId        String
  roleName      String
  guildId       String
  grantedBy     String   // Discord user ID of the admin who granted eligibility
  createdAt     DateTime @default(now())

  pimUser PimUser @relation(fields: [pimUserId], references: [id], onDelete: Cascade)

  @@unique([pimUserId, roleId])
  @@map("eligible_roles")
}

// Currently active (elevated) role sessions
model ActiveElevation {
  id          String    @id @default(cuid())
  pimUserId   String
  roleId      String
  roleName    String
  guildId     String
  elevatedAt  DateTime  @default(now())
  expiresAt   DateTime
  // Set when the expiry warning message is posted; cleared on session extension so warning re-fires
  notifiedAt      DateTime?
  // Discord message IDs of the elevation-granted posts, stored so buttons can be disabled when the session ends
  alertMessageId  String?
  auditMessageId  String?

  pimUser PimUser @relation(fields: [pimUserId], references: [id], onDelete: Cascade)

  @@unique([pimUserId, roleId])
  @@map("active_elevations")
}

// Immutable audit trail of all PIM events
model AuditLog {
  id            String    @id @default(cuid())
  guildId       String
  pimUserId     String?
  discordUserId String
  eventType     AuditEventType
  roleId        String?
  roleName      String?
  metadata      Json?
  createdAt     DateTime  @default(now())

  pimUser PimUser? @relation(fields: [pimUserId], references: [id], onDelete: SetNull)

  @@index([guildId, createdAt])
  @@index([discordUserId])
  @@map("audit_logs")
}

enum AuditEventType {
  PASSWORD_SET
  PASSWORD_CHANGED
  ELEVATION_REQUESTED
  ELEVATION_GRANTED
  ELEVATION_EXPIRED
  ELEVATION_REVOKED
  FAILED_ATTEMPT
  ACCOUNT_LOCKED
  ACCOUNT_UNLOCKED
  ELIGIBILITY_GRANTED
  ELIGIBILITY_REVOKED
  ADMIN_ROLE_CONFIGURED
  ELEVATION_EXPIRY_WARNING
  ELEVATION_EXTENDED
  ELEVATION_ADMIN_REVOKED
  ELEVATION_ADMIN_REVOKED_BLOCKED
  ELEVATION_BLOCKED
  PASSWORD_RESET
  ELEVATION_SELF_REVOKED
}
