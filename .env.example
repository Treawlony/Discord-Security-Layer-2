# ──────────────────────────────────────────────
# Discord Watchtower — Environment Variables
# Copy this file to .env and fill in the values.
# ──────────────────────────────────────────────

# Discord application credentials
DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_application_client_id_here

# PostgreSQL connection (used directly when running outside Docker)
DATABASE_URL=postgresql://watchtower:changeme@localhost:5432/watchtower?schema=public

# PostgreSQL credentials (used by Docker Compose)
POSTGRES_USER=watchtower
POSTGRES_PASSWORD=changeme
POSTGRES_DB=watchtower

# ── PIM defaults (can be overridden per-guild via /watchtower config) ──────────
# Default number of failed password attempts before account lockout
DEFAULT_LOCKOUT_THRESHOLD=5
